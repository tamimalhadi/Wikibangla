{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A wiki article containing knowledge in Bengali.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the article."
        },
        "content": {
          "type": "string",
          "description": "The markdown content of the article."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who created the article."
        },
        "authorName": {
          "type": "string",
          "description": "The display name of the author."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the article was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the article was last updated."
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Categories the article belongs to."
        },
        "language": {
          "type": "string",
          "enum": ["bn", "en"],
          "description": "The language of the article."
        },
        "views": {
          "type": "number",
          "description": "Number of times the article has been viewed."
        }
      },
      "required": ["title", "content", "authorId", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the WikiBangla platform.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "user"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user account was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of wiki articles."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
